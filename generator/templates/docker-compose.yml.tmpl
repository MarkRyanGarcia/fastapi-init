services:
  app:
    build: .
    ports:
      - "8000:8000"
    env_file:
      - .env
    depends_on:
{{- if or .IncludeSQLAlchemy .UseSQLModel .UseFastCRUD }}
      - db
{{- else if .IncludeMongoDB }}
      - mongo
{{- end }}
{{- if .UseRedis }}
      - redis
{{- end }}
    develop:
      watch:
        - action: sync
          path: .
          target: /app
{{- if or .IncludeSQLAlchemy .UseSQLModel .UseFastCRUD }}

  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: user
      POSTGRES_PASSWORD: password
      POSTGRES_DB: {{ .ProjectName }}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
{{- else if .IncludeMongoDB }}

  mongo:
    image: mongo:7
    ports:
      - "27017:27017"
    volumes:
      - mongo_data:/data/db
{{- end }}
{{- if .UseRedis }}

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
{{- end }}

volumes:
{{- if or .IncludeSQLAlchemy .UseSQLModel .UseFastCRUD }}
  postgres_data:
{{- else if .IncludeMongoDB }}
  mongo_data:
{{- end }}
{{- if .UseRedis }}
  redis_data:
{{- end }}
