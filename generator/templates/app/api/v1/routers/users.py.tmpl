from fastapi import APIRouter, Depends
{{- if .UseFastCRUD }}
from sqlmodel import Session
from app.db.session import get_db
from app.schemas.user import UserCreate, UserCreateInternal, UserRead
from app.services.user_service import crud_users
{{- else if .UseSQLModel }}
from sqlmodel import Session
from app.db.session import get_db
from app.schemas.user import UserCreate, UserRead
from app.services.user_service import UserService
{{- else if .IncludeSQLAlchemy }}
from sqlalchemy.orm import Session
from app.db.session import get_db
from app.schemas.user import UserCreate, UserRead
from app.services.user_service import UserService
{{- else if .IncludeMongoDB }}
from pymongo.database import Database
from app.db.session import get_db
from app.schemas.user import UserCreate, UserRead
from app.services.user_service import UserService
{{- else }}
from app.schemas.user import UserCreate, UserRead
from app.services.user_service import UserService
{{- end }}
{{- if or .UseClerk .UseCognito }}
from app.core.security import require_auth, get_optional_auth_id
{{- end }}
{{- if .UseRedis }}
import redis.asyncio as aioredis
from app.core.cache import get_redis
{{- end }}

router = APIRouter()

{{- if .UseFastCRUD }}
@router.get("", response_model=list[UserRead])
async def list_users(
    db: Session = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str | None = Depends(get_optional_auth_id),
{{- end }}
{{- if .UseRedis }}
    redis: aioredis.Redis = Depends(get_redis),
{{- end }}
):
    result = await crud_users.get_multi(db)
    return result["data"]

@router.post("", response_model=UserRead)
async def create_user(
    user: UserCreate,
    db: Session = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str = Depends(require_auth),
{{- end }}
{{- if .UseRedis }}
    redis: aioredis.Redis = Depends(get_redis),
{{- end }}
):
    return await crud_users.create(db, UserCreateInternal(**user.model_dump()))
{{- else if or .UseSQLModel .IncludeSQLAlchemy }}
@router.get("", response_model=list[UserRead])
async def list_users(
    db: Session = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str | None = Depends(get_optional_auth_id),
{{- end }}
{{- if .UseRedis }}
    redis: aioredis.Redis = Depends(get_redis),
{{- end }}
):
    return UserService.get_all(db)

@router.post("", response_model=UserRead)
async def create_user(
    user: UserCreate,
    db: Session = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str = Depends(require_auth),
{{- end }}
{{- if .UseRedis }}
    redis: aioredis.Redis = Depends(get_redis),
{{- end }}
):
    return UserService.create(db, user)
{{- else if .IncludeMongoDB }}
@router.get("", response_model=list[UserRead])
async def list_users(
    db: Database = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str | None = Depends(get_optional_auth_id),
{{- end }}
{{- if .UseRedis }}
    redis: aioredis.Redis = Depends(get_redis),
{{- end }}
):
    return UserService.get_all(db)

@router.post("", response_model=UserRead)
async def create_user(
    user: UserCreate,
    db: Database = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str = Depends(require_auth),
{{- end }}
{{- if .UseRedis }}
    redis: aioredis.Redis = Depends(get_redis),
{{- end }}
):
    return UserService.create(db, user)
{{- else }}
@router.get("", response_model=list[UserRead])
async def list_users(
{{- if or .UseClerk .UseCognito }}
    user_id: str | None = Depends(get_optional_auth_id),
{{- end }}
{{- if .UseRedis }}
    redis: aioredis.Redis = Depends(get_redis),
{{- end }}
):
    return await UserService.get_all()

@router.post("", response_model=UserRead)
async def create_user(
    user: UserCreate,
{{- if or .UseClerk .UseCognito }}
    user_id: str = Depends(require_auth),
{{- end }}
{{- if .UseRedis }}
    redis: aioredis.Redis = Depends(get_redis),
{{- end }}
):
    return await UserService.create(user)
{{- end }}
