APP_NAME="{{ .ProjectName }}"
{{- if or .IncludeSQLAlchemy .UseSQLModel .UseFastCRUD }}
{{- if .UseDocker }}
DATABASE_URL="postgresql://user:password@db:5432/{{ .ProjectName }}"
{{- else }}
DATABASE_URL="postgresql://user:password@localhost:5432/{{ .ProjectName }}"
{{- end }}
{{- else if .IncludeMongoDB }}
{{- if .UseDocker }}
MONGODB_URL="mongodb://mongo:27017"
{{- else }}
MONGODB_URL="mongodb://localhost:27017"
{{- end }}
MONGODB_DB="{{ .ProjectName }}"
{{- end }}
{{- if .UseClerk }}
CLERK_SECRET_KEY="sk_test.."
{{- else if .UseCognito }}
AWS_REGION="us-east-1"
COGNITO_USER_POOL_ID=""
COGNITO_APP_CLIENT_ID=""
{{- end }}
{{- if .UseRedis }}
REDIS_URL="redis://{{ if .UseDocker }}redis{{ else }}localhost{{ end }}:6379"
{{- end }}
